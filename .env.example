# Solana Chain Scanner — Bot 2 (TON/BSC env YOK)

BOT_TOKEN=
# Admin Telegram user id (admin komutları)
ADMIN_USER_ID=7399188880

# Premium animasyonlu emoji → bu hesabın MTProto oturumu (my.telegram.org API)
# Session: node scripts/generate-session.js (7399188880 hesabının telefonu ile giriş)
TG_API_ID=
TG_API_HASH=
TG_SESSION=
# 1 = userbot varsa kanal postları MTProto ile (premium emoji). Session yoksa otomatik Bot API fallback.
CHANNEL_USERBOT_REQUIRED=1
# USERBOT_SEND_AS_CHANNEL=0

# Kalıcı ayarlar (Railway Volume mount /data veya DATA_DIR=/data) — yoksa her deploy sıfırlar
# DATA_DIR=/data
# TELEGRAM_CHANNEL_ID=-1001234567890
# Virgülle birden fazla kanal yedek (deploy sonrası otomatik yeniden kayıt)
# TELEGRAM_CHANNEL_IDS=-100111,-100222

SOLANA_RPC_URL=
HELIUS_API_KEY=

# Pump.fun keşfi (DexScreener pump mint + isteğe bağlı Pump API / RPC)
PUMP_DISCOVERY_ENABLED=1
PUMP_DEXSCREENER_DISCOVERY=1
PUMP_FUN_API_ENABLED=1
PUMP_FUN_API_BASE=https://frontend-api-v3.pump.fun
# PUMP_FUN_JWT=   # pump.fun sitesinden oturum JWT (API Cloudflare engellerse zorunlu olabilir)
# PUMP_RPC_DISCOVERY=1   # SOLANA_RPC_URL ile zincirden yeni pump mint (Helius/QuickNode önerilir)

SOLANA_SCAN_ENABLED=0
SOLANA_SCAN_INTERVAL_MIN=12
SOLANA_SCAN_POOL_LIMIT=12
SOLANA_SCAN_TOKEN_GAP_MS=1200

WATCH_INTERVAL_SECONDS=60
WATCH_BATCH_SIZE=3
WATCH_BATCH_DELAY_MS=400
MAX_TOKENS_PER_SCAN=8

# Banner file_id (opsiyonel — yoksa assets/solana/*.jpg)
# SOLANA_GREEN_BANNER_FILE_ID=
# SOLANA_RISK_BANNER_FILE_ID=
# SOLANA_CRITICAL_BANNER_FILE_ID=
# SOLANA_SCAM_BANNER_FILE_ID=
