# Solana Chain Scanner — Bot 2 (TON/BSC env YOK)
#
# ── İKİ AYRI ŞEY (aynı Telegram hesabında birden fazla BotFather botu olabilir) ──
# 1) BOT_TOKEN  = @solachainscanbot (veya sizin Solana botunuz) — BotFather API token
# 2) TG_SESSION = kişisel hesabınızın oturumu (userbot, premium emoji) — BOT DEĞİL
# TON botunun token'ını buraya KOYMAYIN. Polling 409 = aynı token iki yerde çalışıyor.
# Yerel PC'de npm start + Railway aynı BOT_TOKEN → 409 Conflict.

BOT_TOKEN=
# Dil: bot içi ayarlardan seçilir (varsayılan en). BOT_LANG artık kullanılmıyor.
# Premium emoji (Solana-only): src/emojiPack.js SOLANA_EMOJI_MAP
# Railway'de tek seferde güncelleme: SOLANA_CUSTOM_EMOJI_JSON={"🔥":"123","◎":"456"}

# Al/Sat: auto (varsayılan) = token DEX'ine göre (Pump/Raydium/Orca/Meteora/Phantom)
# Zorlama: phantom | jupiter | pump
TRADE_LINK_PROVIDER=auto
# Admin Telegram user id (admin komutları)
ADMIN_USER_ID=7399188880

# Premium animasyonlu emoji → KİŞİSEL hesap MTProto (my.telegram.org → API development tools)
# Session: node scripts/generate-session.js (telefon + SMS, BotFather botu değil)
TG_API_ID=
TG_API_HASH=
TG_SESSION=
# 1 = TG_SESSION zorunlu (yoksa kanala post gitmez). Session var ama bağlanamazsa Bot API dener.
# 0 = her zaman Bot API (premium emoji düz metin olabilir)
CHANNEL_USERBOT_REQUIRED=0
# USERBOT_SEND_AS_CHANNEL=0

# ÇOK KANALLI BOT: Railway Volume mount /data (bir kez) — her kullanıcı kanala botu ekler, otomatik kayıt.
# TELEGRAM_CHANNEL_IDS = sadece sunucu sahibi acil yedek; her kanal sahibi ELLE eklemez.
# DATA_DIR=/data
# TELEGRAM_CHANNEL_IDS=-100111,-100222
# Deploy sonrası yeniden keşifte ◎ Solana otomatik (0 = DM'den seç)
# AUTO_SELECT_SOLANA_ON_SYNC=1

# Helius: dashboard → API Keys → tablodaki UUID (Key ID sütunu) = HELIUS_API_KEY
# SOLANA_RPC_URL boş bırakın; bot otomatik https://mainnet.helius-rpc.com/?api-key=... üretir
SOLANA_RPC_URL=
HELIUS_API_KEY=

# Solana kontrat güvenliği (ücretsiz katmanlar — varsayılan AÇIK)
# RUGCHECK_ENABLED=1
# RUGCHECK_FULL_REPORT=1
# GOPLUS_SOLANA_ENABLED=1
# HELIUS_HOLDERS_ENABLED=1
# RUGCHECK_JWT=   # isteğe bağlı (yoğun kullanımda)
# GOPLUS_API_KEY= # Solana uç noktası çoğu zaman keysiz çalışır

# Pump.fun keşfi (DexScreener pump mint + isteğe bağlı Pump API / RPC)
PUMP_DISCOVERY_ENABLED=1
PUMP_DEXSCREENER_DISCOVERY=1
PUMP_FUN_API_ENABLED=1
PUMP_FUN_API_BASE=https://frontend-api-v3.pump.fun
# PUMP_FUN_JWT=   # pump.fun sitesinden oturum JWT (API Cloudflare engellerse zorunlu olabilir)
# PUMP_RPC_DISCOVERY=1   # SOLANA_RPC_URL ile zincirden yeni pump mint (Helius/QuickNode önerilir)

# Mini App feed üstünde test tokenları (BONK, WIF, …) — kapatmak için 0
MINI_APP_SEED=1

SOLANA_SCAN_ENABLED=0
SOLANA_SCAN_INTERVAL_MIN=12
SOLANA_SCAN_POOL_LIMIT=12
SOLANA_SCAN_TOKEN_GAP_MS=1200

WATCH_INTERVAL_SECONDS=60
WATCH_BATCH_SIZE=3
WATCH_BATCH_DELAY_MS=400
MAX_TOKENS_PER_SCAN=8

# Mini App — tam denetim raporu (kanal yorumunda tek güven kartı + buton)
# Railway: WEB_APP_URL=https://SIZIN-SERVIS.up.railway.app  (HTTPS zorunlu)
# BotFather → Bot Settings → Menu Button → Web App URL (aynı adres)
MINI_APP_ENABLED=1
# MINI_APP_PORT=3080   # yerel; Railway'de PORT otomatik
WEB_APP_URL=

# Banner file_id (opsiyonel — yoksa assets/solana/*.jpg)
# SOLANA_GREEN_BANNER_FILE_ID=
# SOLANA_RISK_BANNER_FILE_ID=
# SOLANA_CRITICAL_BANNER_FILE_ID=
# SOLANA_SCAM_BANNER_FILE_ID=
