# Sniper Scan Bot — TON + BSC + Solana (tek BOT_TOKEN)
#
# 1) BOT_TOKEN  = BotFather API token (yalnızca TEK serviste çalışsın)
# 2) TG_SESSION = kişisel hesap (userbot, premium emoji) — BOT DEĞİL
# Polling 409 = aynı token iki yerde (PC + Railway) veya eski TON/Solana botları hâlâ açık.

BOT_TOKEN=
# Dil: bot içi ayarlardan seçilir (varsayılan en). BOT_LANG artık kullanılmıyor.
# Premium emoji (Solana-only): src/emojiPack.js SOLANA_EMOJI_MAP
# Railway'de tek seferde güncelleme: SOLANA_CUSTOM_EMOJI_JSON={"🔥":"123","◎":"456"}

# Al/Sat: auto (varsayılan) = token DEX'ine göre (Pump/Raydium/Orca/Meteora/Phantom)
# Zorlama: phantom | jupiter | pump
TRADE_LINK_PROVIDER=auto
# Admin Telegram user id (admin komutları)
# Virgülle birden fazla: 8215553438,7399188880
ADMIN_USER_ID=8215553438

# Premium animasyonlu emoji → KİŞİSEL hesap MTProto (my.telegram.org → API development tools)
# Session: node scripts/generate-session.js (telefon + SMS, BotFather botu değil)
TG_API_ID=
TG_API_HASH=
TG_SESSION=
# 1 = TG_SESSION zorunlu (yoksa kanala post gitmez). Session var ama bağlanamazsa Bot API dener.
# 0 = her zaman Bot API (premium emoji düz metin olabilir)
CHANNEL_USERBOT_REQUIRED=0
# USERBOT_SEND_AS_CHANNEL=0

# ÇOK KANALLI BOT: Railway Volume mount /data (bir kez) — her kullanıcı kanala botu ekler, otomatik kayıt.
# TELEGRAM_CHANNEL_IDS = sadece sunucu sahibi acil yedek; her kanal sahibi ELLE eklemez.
#
# Mini App feed — YALNIZCA bu kanal ID'lerindeki paylaşımlar listelenir (virgülle).
# Tanımlı değilse TELEGRAM_CHANNEL_IDS kullanılır. Başka kanallar yalnızca scanner (kart), app'e yazılmaz.
# Resmi ◎ Solana kanal (Railway ile aynı tutun)
MINI_APP_FEED_CHANNEL_IDS=-1003992932638
TELEGRAM_CHANNEL_IDS=-1003992932638
# DATA_DIR=/app/data
# Volume çalışmıyorsa: Railway → + New → PostgreSQL → bot servisine bağla (DATABASE_URL otomatik gelir)
# DATABASE_URL=postgresql://...

# ── DEX kırpma kilidi (5 cihaz onaylandıktan sonra) — DEX servis Variables ──
# CROP_LOCK_PROFILES=1
# CROP_SAVE_PIN=ozel-sifren (yoksa varsayilan: SniperKirpma9)
# CROP_PUBLISH_KEY=uzun-gizli-anahtar
# (Panel herkes acabilir; slider/kaydet sunucu sifresi — Railway'de CROP_SAVE_PIN ile degistir)
# (Kilit açıkken panel POST reddedilir; güncelleme: git + node scripts/push-crop-profiles.js)

# ── DEX kullanıcı botu (@dexscannerappbot) — MINIAPP_ONLY=1 + BOT_TOKEN ──
# MINIAPP_ONLY=1
# BOT_SERVICE_ROLE=dex
# DEX_OFFICIAL_CHANNEL_URL=https://t.me/your_official_channel
# DEX_BOT_USERNAME=dexscannerappbot
# SCAN_BOT_USERNAME=solanachainscanbot
# BotFather Description — elle; deploy sadece eski API en/tr/ru kilidini siler (DEX bot)
# BOT_SKIP_CLEAR_API_DESCRIPTIONS=1  → temizlik kapalı
# /start karşılama foto+metin kodda (dexWelcome); profil açıklaması değil
# DATABASE_URL=${{ Postgres.DATABASE_URL }}
# (HTTP proxy yerine DB; timeout / döngü olmaz)
#
# Alternatif (Postgres yoksa): iç ağ — public domain DEX ile aynı olmasın
# BOT_RAILWAY_PRIVATE_DOMAIN=${{ solana-chain-scanner.RAILWAY_PRIVATE_DOMAIN }}
# BOT_SERVICE_PORT=8080
# (üstte TELEGRAM_CHANNEL_IDS — resmi Solana kanal)
# Deploy sonrası yeniden keşifte ◎ Solana otomatik (0 = DM'den seç)
# AUTO_SELECT_SOLANA_ON_SYNC=1

# Helius: dashboard → API Keys → tablodaki UUID (Key ID sütunu) = HELIUS_API_KEY
# SOLANA_RPC_URL boş bırakın; bot otomatik https://mainnet.helius-rpc.com/?api-key=... üretir
SOLANA_RPC_URL=
HELIUS_API_KEY=

# Solana kontrat güvenliği (ücretsiz katmanlar — varsayılan AÇIK)
# RUGCHECK_ENABLED=1
# RUGCHECK_FULL_REPORT=1
# GOPLUS_SOLANA_ENABLED=1
# HELIUS_HOLDERS_ENABLED=1
# RUGCHECK_JWT=   # isteğe bağlı (yoğun kullanımda)
# GOPLUS_API_KEY= # Solana uç noktası çoğu zaman keysiz çalışır

# Pump.fun keşfi (DexScreener pump mint + isteğe bağlı Pump API / RPC)
PUMP_DISCOVERY_ENABLED=1
PUMP_DEXSCREENER_DISCOVERY=1
PUMP_FUN_API_ENABLED=1
PUMP_FUN_API_BASE=https://frontend-api-v3.pump.fun
# PUMP_FUN_JWT=   # pump.fun sitesinden oturum JWT (API Cloudflare engellerse zorunlu olabilir)
# PUMP_RPC_DISCOVERY=1   # SOLANA_RPC_URL ile zincirden yeni pump mint (Helius/QuickNode önerilir)

# Mini App örnek tokenları (BONK, WIF, …) — yalnızca yerel test; üretimde kapalı
# MINI_APP_SEED=1
# New Pairs demo listesi — yalnızca yerel test
# MINI_APP_NEW_PAIRS_PREVIEW=1

# Otomatik tarama (kanal ayarında seçilen ağa göre)
TON_SCAN_ENABLED=1
TON_SCAN_INTERVAL_MIN=12
BSC_SCAN_ENABLED=0
BSC_SCAN_INTERVAL_MIN=12
SOLANA_SCAN_ENABLED=0
SOLANA_SCAN_INTERVAL_MIN=12
SOLANA_SCAN_POOL_LIMIT=12
SOLANA_SCAN_TOKEN_GAP_MS=1200

WATCH_INTERVAL_SECONDS=60
WATCH_BATCH_SIZE=3
WATCH_BATCH_DELAY_MS=400
MAX_TOKENS_PER_SCAN=8

# Mini App — tam denetim raporu (kanal yorumunda tek güven kartı + buton)
# Railway: WEB_APP_URL = bot servisinin public HTTPS domain'i (Settings'teki Sniper DEX aynı URL)
# BotFather → Menu Button → Web App URL (birebir aynı; eski DEX domain'i bırakmayın)
# Eski DEX servisinde liste varken Settings boşsa: bot servisine DATABASE_URL=${{ Postgres.DATABASE_URL }}
MINI_APP_ENABLED=1
# MINI_APP_PORT=3080   # yerel; Railway'de PORT otomatik
WEB_APP_URL=

# Banner file_id (opsiyonel — yoksa assets/solana/*.jpg)
# SOLANA_GREEN_BANNER_FILE_ID=
# SOLANA_RISK_BANNER_FILE_ID=
# SOLANA_CRITICAL_BANNER_FILE_ID=
# SOLANA_SCAM_BANNER_FILE_ID=

# Mini App üst reklam (GIF + link)
MINI_APP_BANNER_ENABLED=1
# Cihaza göre 3 banner (önerilen: bilgisayar 1200×144, tablet 768×120, telefon 390×96)
# MINI_APP_BANNER_DESKTOP_URL=https://sizin-cdn.com/banner-desktop.png
# MINI_APP_BANNER_TABLET_URL=https://sizin-cdn.com/banner-tablet.png
# MINI_APP_BANNER_MOBILE_URL=https://sizin-cdn.com/banner-mobile.png
# MINI_APP_BANNER_GIF_URL=https://sizin-cdn.com/reklam.gif
# MINI_APP_BANNER_LINK=https://t.me/kanal
# MINI_APP_BANNER_ALT=Sponsor
# Mini App banner — yalnızca /admin/ panelinden (POST /api/admin/promo-banner, giriş gerekir)

# Admin panel — https://SIZIN-SERVIS/admin/ (kullanıcı adı + şifre)
# ADMIN_USERNAME=admin
# ADMIN_PASSWORD=guclu-sifre-buraya
# ADMIN_SESSION_SECRET=istege-bagli-ek-gizlilik
